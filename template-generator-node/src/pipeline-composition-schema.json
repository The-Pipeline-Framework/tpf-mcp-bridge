{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelineframework.org/schemas/pipeline-composition.schema.json",
  "title": "Pipeline Composition Manifest",
  "description": "Companion manifest that groups pipeline YAML files into a typed checkpoint-handoff composition.",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "pipelines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 80,
            "pattern": "^[a-zA-Z][a-zA-Z0-9._-]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "required": [
          "id",
          "path"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "name",
    "pipelines"
  ],
  "additionalProperties": false
}
