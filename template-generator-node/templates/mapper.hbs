package {{basePackage}}.common.mapper;

import jakarta.enterprise.context.ApplicationScoped;
import {{basePackage}}.common.domain.{{domainClass}};
import {{basePackage}}.common.dto.{{dtoClass}};
import org.pipelineframework.mapper.Mapper;

@ApplicationScoped
public class {{className}}Mapper implements Mapper<{{domainClass}}, {{dtoClass}}> {

  @Override
  public {{domainClass}} fromExternal({{dtoClass}} external) {
    if (external == null) {
      return null;
    }
    {{domainClass}} target = new {{domainClass}}();
{{#each fields}}
{{#unless (isIdField this.name)}}
    target.{{javaName}} = external.{{javaName}};
{{/unless}}
{{/each}}
    return target;
  }

  @Override
  public {{dtoClass}} toExternal({{domainClass}} domain) {
    if (domain == null) {
      return null;
    }
    {{dtoClass}} target = new {{dtoClass}}();
{{#each fields}}
{{#unless (isIdField this.name)}}
    target.{{javaName}} = domain.{{javaName}};
{{/unless}}
{{/each}}
    return target;
  }
}
