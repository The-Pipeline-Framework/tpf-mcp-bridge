{{#if isGrpcTransport}}
# Vert.x configuration
quarkus.grpc.server.use-separate-server=false
quarkus.http.host-enabled=true

# REST alternative:
# quarkus.http.ssl-port=8443

# quarkus.grpc.server.use-separate-server=false
# quarkus.grpc.server.plain-text=false
# quarkus.http.ssl.certificate.key-store-file=${SERVER_KEYSTORE_PATH:../target/dev-certs/orchestrator-svc/server-keystore.jks}
# quarkus.http.ssl.certificate.key-store-password=secret
# quarkus.http.insecure-requests=disabled
# quarkus.http.enable-compression=true
# quarkus.rest-client.http2=true
{{/if}}

{{#if isRestTransport}}
quarkus.http.ssl-port=8443

# Vert.x configuration
quarkus.grpc.server.use-separate-server=false
quarkus.grpc.server.plain-text=false
quarkus.http.ssl.certificate.key-store-file=${SERVER_KEYSTORE_PATH:../target/dev-certs/orchestrator-svc/server-keystore.jks}
quarkus.http.ssl.certificate.key-store-password=secret
quarkus.http.insecure-requests=disabled
quarkus.http.enable-compression=true
quarkus.rest-client.http2=true

# gRPC alternative:
# Vert.x configuration
#quarkus.grpc.server.use-separate-server=false
#quarkus.http.host-enabled=true
{{/if}}

# Pipeline Configuration
pipeline.defaults.retry-limit=10
pipeline.defaults.retry-wait-ms=500
pipeline.defaults.recover-on-failure=false
pipeline.defaults.max-backoff=30000
pipeline.defaults.jitter=false
{{#if hasQueueAsyncRuntime}}

# Await steps, command steps, and checkpoint hand-offs require queue-async orchestration so executions can park, replay effects, resume, or publish boundaries.
pipeline.orchestrator.mode=QUEUE_ASYNC
# Set TPF_RESUME_TOKEN_SECRET to a deployment secret before starting a queue-async runtime.
pipeline.orchestrator.resume-token-secret=${TPF_RESUME_TOKEN_SECRET}

# Operator-owned redrive/replay policy remains external to the scaffold.
{{#if hasCommandSteps}}
# Keep command connectors idempotent over deterministic command ids. Configure provider endpoints and credentials outside pipeline.yaml.
{{/if}}
{{#if hasAwaitSteps}}
# Keep await handlers idempotent over the configured idempotencyKeyFields.
{{/if}}
{{#if hasCheckpointBoundaries}}
# Keep checkpoint publishers/subscribers idempotent over the configured boundary key fields.
{{/if}}
{{#if hasKafkaAwait}}

# Kafka await transport starter settings.
{{#if kafkaAwait}}
tpf.await.kafka.reactive-messaging.enabled=true
kafka.bootstrap.servers=${KAFKA_BOOTSTRAP_SERVERS:localhost:9092}
mp.messaging.outgoing.tpf-await-kafka-requests.connector=smallrye-kafka
mp.messaging.outgoing.tpf-await-kafka-requests.topic={{kafkaAwait.requestTopic}}
mp.messaging.outgoing.tpf-await-kafka-requests.value.serializer=org.apache.kafka.common.serialization.StringSerializer
mp.messaging.incoming.tpf-await-kafka-responses.connector=smallrye-kafka
mp.messaging.incoming.tpf-await-kafka-responses.topic={{kafkaAwait.responseTopic}}
mp.messaging.incoming.tpf-await-kafka-responses.group.id={{kafkaAwait.consumerGroupProperty}}
mp.messaging.incoming.tpf-await-kafka-responses.auto.offset.reset=${TPF_AWAIT_KAFKA_RESPONSES_OFFSET_RESET:earliest}
mp.messaging.incoming.tpf-await-kafka-responses.value.deserializer=org.apache.kafka.common.serialization.StringDeserializer
{{else}}
# mp.messaging.outgoing.<await-request-channel>.topic=<request-topic>
# mp.messaging.incoming.<await-response-channel>.topic=<response-topic>
# mp.messaging.incoming.<await-response-channel>.group.id={{rootProjectName}}-await-responses
{{/if}}
{{/if}}
{{#if hasSqsAwait}}

# SQS await transport starter settings.
tpf.await.sqs.poller.enabled=true
tpf.await.sqs.request-queue-url=${TPF_AWAIT_SQS_REQUEST_QUEUE_URL}
tpf.await.sqs.response-queue-url=${TPF_AWAIT_SQS_RESPONSE_QUEUE_URL}
quarkus.sqs.aws.region=${AWS_REGION:us-east-1}
quarkus.sqs.endpoint-override=${SQS_ENDPOINT_OVERRIDE:}
{{/if}}
{{#if hasWebhookAwait}}

# Webhook await transport starter settings.
# tpf.await.webhook.callback-base-url=${TPF_AWAIT_WEBHOOK_CALLBACK_BASE_URL}
{{/if}}
{{#if hasInteractionApiAwait}}

# Interaction API await transport starter settings.
# tpf.await.interaction-api.base-path=/pipeline/interactions
{{/if}}
{{/if}}
{{#if hasCacheAspect}}
pipeline.cache.policy=prefer-cache

# Cache provider configuration (build-time)
# Choose one: redis | caffeine | memory
pipeline.cache.provider=redis
%prod.quarkus.redis.hosts=${REDIS_HOSTS:redis://localhost:6379}
%dev.quarkus.redis.devservices.enabled=true
%test.quarkus.redis.devservices.enabled=true

# Caffeine (in-process) alternative:
# pipeline.cache.provider=caffeine
# pipeline.cache.caffeine.name=pipeline-cache
# pipeline.cache.caffeine.maximum-size=10000
# pipeline.cache.caffeine.expire-after-write=PT30M
# pipeline.cache.caffeine.expire-after-access=PT30M

# In-memory (simple map) alternative:
# pipeline.cache.provider=memory
{{/if}}
{{#if hasJpaQuery}}

# JPA query connector starter settings.
quarkus.datasource.db-kind=${TPF_QUERY_JPA_DB_KIND:postgresql}
%dev.quarkus.datasource.devservices.enabled=true
%test.quarkus.datasource.devservices.enabled=true
# quarkus.datasource.reactive.url=${TPF_QUERY_JPA_REACTIVE_URL}
# quarkus.datasource.username=${TPF_QUERY_JPA_USERNAME}
# quarkus.datasource.password=${TPF_QUERY_JPA_PASSWORD}
# quarkus.hibernate-orm.packages={{basePackage}}.common.domain
{{/if}}
{{#if hasObjectIngest}}

# Object ingest connector starter.
# Object source provider/location/polling settings are declared in config/pipeline.yaml under sources and input.object.
{{/if}}

# Client wiring defaults (endpoints generated by the annotation processor)
# A module groups one or more services into the same runtime (for example, legacy layouts).
# Client overrides target a single step or synthetic side-effect client.
# pipeline.client.base-port=8443
# pipeline.module.<module>.host=localhost
# pipeline.module.<module>.port=8444
# pipeline.module.<module>.steps=process-foo,process-bar
# pipeline.module.<module>.aspects=persistence,cache
# pipeline.client.tls-configuration-name=pipeline-client
# quarkus.grpc.clients.<client>.host=host
# quarkus.grpc.clients.<client>.port=8444
# quarkus.rest-client.<client>.url=https://host:8444

# TLS configuration (optional shared registry)
# quarkus.tls.pipeline-client.trust-store.jks.path=${CLIENT_TRUSTSTORE_PATH:../target/dev-certs/orchestrator-svc/client-truststore.jks}
# quarkus.tls.pipeline-client.trust-store.jks.password=secret

# Micrometer configuration
quarkus.micrometer.export.prometheus.enabled=${QUARKUS_MICROMETER_EXPORT_PROMETHEUS_ENABLED:false}
quarkus.micrometer.export.prometheus.path=/q/metrics
quarkus.micrometer.binder.http-server.enabled=${QUARKUS_OTEL_METRICS_ENABLED:${QUARKUS_MICROMETER_EXPORT_PROMETHEUS_ENABLED:true}}
quarkus.micrometer.binder.http-client.enabled=${QUARKUS_OTEL_METRICS_ENABLED:${QUARKUS_MICROMETER_EXPORT_PROMETHEUS_ENABLED:true}}
quarkus.micrometer.binder.jvm=true

# OpenTelemetry configuration
# Prometheus export is opt-in to avoid running LGTM/Prometheus by default in dev.
# The following defaults only apply when OpenTelemetry is enabled (for example via NEW_RELIC_LICENSE_KEY).
# For non-local deployments, set OTEL_EXPORTER_OTLP_ENDPOINT or quarkus.otel.exporter.otlp.endpoint.
# quarkus.otel.exporter.otlp.endpoint=${OTEL_EXPORTER_OTLP_ENDPOINT}
quarkus.otel.exporter.otlp.endpoint=http://otel-collector:4318
quarkus.otel.exporter.otlp.protocol=http/protobuf
quarkus.otel.exporter.otlp.compression=gzip
quarkus.otel.exporter.otlp.metrics.temporality.preference=delta
quarkus.otel.traces.enabled=true
quarkus.otel.metrics.enabled=true
quarkus.otel.logs.enabled=true
quarkus.otel.metric.export.interval=${QUARKUS_OTEL_METRIC_EXPORT_INTERVAL:10s}
quarkus.otel.traces.sampler=parentbased_traceidratio
quarkus.otel.traces.sampler.arg=0.001
quarkus.otel.resource.attributes=service.instance.id=${HOSTNAME:unknown}

# Docker image
quarkus.container-image.builder=jib
quarkus.container-image.registry=localhost
quarkus.container-image.group={{rootProjectName}}
quarkus.container-image.name={{serviceName}}
quarkus.container-image.tag=latest
