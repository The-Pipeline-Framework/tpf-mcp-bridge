{
  "name": "@pipelineframework/tpf-mcp-bridge",
  "version": "0.1.4",
  "description": "Local MCP bridge for TPF brief-to-scaffold sessions with a local planner and optional hosted generation backend",
  "license": "Apache-2.0",
  "homepage": "https://github.com/The-Pipeline-Framework/tpf-mcp-bridge",
  "bugs": {
    "url": "https://github.com/The-Pipeline-Framework/tpf-mcp-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Pipeline-Framework/tpf-mcp-bridge.git"
  },
  "keywords": [
    "mcp",
    "codex",
    "openai",
    "pipeline-framework",
    "tpf"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/src/bridge-runtime.js",
  "exports": {
    ".": "./dist/src/bridge-runtime.js"
  },
  "bin": {
    "tpf-mcp-bridge": "./dist/src/bridge.js"
  },
  "files": [
    "dist/src/**/*",
    "template-generator-node/src/**/*",
    "template-generator-node/templates/**/*",
    "template-generator-node/package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/src/bridge.js",
    "start:local": "node dist/src/server.js",
    "start:worker": "wrangler dev src/worker.ts",
    "deploy:worker": "wrangler deploy src/worker.ts",
    "sync:pipeline-schema": "node scripts/sync-pipeline-schema.mjs",
    "audit:release-parity": "node scripts/audit-release-parity.mjs",
    "smoke:rest-await-union": "node scripts/smoke-rest-await-union-compile.mjs",
    "smoke:kafka-await": "node scripts/smoke-kafka-await-compile.mjs",
    "smoke:sqs-await": "node scripts/smoke-sqs-await-compile.mjs",
    "smoke:query-connector": "node scripts/smoke-query-connector-compile.mjs",
    "smoke:object-ingest": "node scripts/smoke-object-ingest-compile.mjs",
    "smoke:checkpoint-composition": "node scripts/smoke-checkpoint-composition.mjs",
    "check:pipeline-schema": "node scripts/check-pipeline-schema.mjs",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "^8.18.0",
    "js-yaml": "4.1.0",
    "jszip": "^3.10.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.9.0",
    "typescript": "5.9.3",
    "wrangler": "^4.81.1"
  }
}
